{
    "version": 2,
    "builds": [
        {
            "src": "client/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "https://hotel-booking-system-1-fnsh.onrender.com/api/$1"
        },
        {
            "src": "/uploads/(.*)",
            "dest": "https://hotel-booking-system-1-fnsh.onrender.com/uploads/$1"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}
