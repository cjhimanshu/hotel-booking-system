{
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://hotel-booking-system-1-fnsh.onrender.com/api/:path*"
        },
        {
            "source": "/uploads/:path*",
            "destination": "https://hotel-booking-system-1-fnsh.onrender.com/uploads/:path*"
        },
        {
            "source": "/((?!assets/).*)",
            "destination": "/index.html"
        }
    ]
}
